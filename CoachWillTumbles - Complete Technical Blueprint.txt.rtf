\f1\b0 \cf4 \cb1 \strokec4 \
\pard\pardeftab720\partightenfactor0
\cf5 \cb3 \strokec5 -\cf4 \strokec4  Primary: Parents of young gymnasts (ages 4-18)\cb1 \
\cf5 \cb3 \strokec5 -\cf4 \strokec4  Secondary: Gymnastics coach (admin interface)\cb1 \
\cf5 \cb3 \strokec5 -\cf4 \strokec4  Tertiary: Young athletes (supervised usage)\cb1 \
\
\pard\pardeftab720\partightenfactor0

