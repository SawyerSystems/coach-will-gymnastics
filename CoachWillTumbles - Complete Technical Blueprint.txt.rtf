\cb3 ## 6. BACKEND (Express)\cb1 \
\
\cb3 ### Middleware Stack\cb1 \
\
\cb3 #### Core Middleware\cb1 \
\cb3 ```typescript\cb1 \
\cb3 app.use(express.json());           // JSON body parsing\cb1 \
\cb3 app.use(express.urlencoded());     // URL-encoded form data\cb1 \
\cb3 app.use(cors(\{                     // CORS configuration\cb1 \
\cb3   origin: process.env.FRONTEND_URL,\cb1 \
\cb3   credentials: true\cb1 \
\cb3 \}));\cb1 \
\cb3 app.use(session(\{                  // Session management\cb1 \
\cb3   secret: process.env.SESSION_SECRET,\cb1 \
\cb3   resave: false,\cb1 \
\cb3   saveUninitialized: false,\cb1 \
\cb3   cookie: \{\cb1 \
\cb3     secure: process.env.NODE_ENV === 'production',\cb1 \
\cb3     domain: process.env.NODE_ENV === 'production' ? '.coachwilltumbles.com' : undefined,\cb1 \
\cb3     sameSite: 'none',\cb1 \
\cb3     maxAge: 7 * 24 * 60 * 60 * 1000 // 7 days\cb1 \
\cb3   \}\cb1 \
\cb3 \}));\cb1 \
\cb3 ```\cb1 \
\
\cb3 #### Authentication Middleware\cb1 \
\cb3 ```typescript\cb1 \
\cb3 // Admin authentication\cb1 \
\cb3 const isAdminAuthenticated = (req, res, next) => \{\cb1 \
\cb3   if (req.session.adminId) \{\cb1 \
\cb3     return next();\cb1 \
\cb3   \}\cb1 \
\cb3   return res.status(401).json(\{ error: 'Admin authentication required' \});\cb1 \
\cb3 \};\cb1 \
\
\cb3 // Parent authentication\cb1 \
\cb3 const isParentAuthenticated = (req, res, next) => \{\cb1 \
\cb3   if (req.session.parentId) \{\cb1 \
\cb3     return next();\cb1 \
\cb3   \}\cb1 \
\cb3   return res.status(401).json(\{ error: 'Parent authentication required' \});\cb1 \
\cb3 \};\cb1 \
\cb3 ```\cb1 \
\
