\cb3     </Body>\cb1 \
\cb3   </Html>\cb1 \
\cb3 );\cb1 \
\cb3 ```\cb1 \
\
\cb3 ### Email Delivery System\cb1 \
\
\cb3 #### Resend Configuration\cb1 \
\cb3 ```typescript\cb1 \
\cb3 const resend = new Resend(process.env.RESEND_API_KEY);\cb1 \
\
\cb3 const sendEmail = async (\cb1 \
\cb3   template: EmailTemplate,\cb1 \
\cb3   recipient: string,\cb1 \
\cb3   data: EmailData\cb1 \
\cb3 ) => \{\cb1 \
\cb3   try \{\cb1 \
\cb3     const result = await resend.emails.send(\{\cb1 \
\cb3       from: 'Coach Will <coach@coachwilltumbles.com>',\cb1 \
\cb3       to: recipient,\cb1 \
\cb3       subject: template.subject,\cb1 \
\cb3       html: template.render(data),\cb1 \
\cb3     \});\cb1 \
\cb3     \cb1 \
\cb3     // Log email in database\cb1 \
\cb3     await logEmail(\{\cb1 \
\cb3       recipient,\cb1 \
\cb3       template: template.name,\cb1 \
\cb3       status: 'sent',\cb1 \
\cb3       messageId: result.id,\cb1 \
\cb3       sentAt: new Date()\cb1 \
\cb3     \});\cb1 \
\cb3     \cb1 \
\cb3     return result;\cb1 \
\cb3   \} catch (error) \{\cb1 \
\cb3     await logEmail(\{\cb1 \
\cb3       recipient,\cb1 \
\cb3       template: template.name,\cb1 \
\cb3       status: 'failed',\cb1 \
\cb3       error: error.message,\cb1 \
\cb3       sentAt: new Date()\cb1 \
\cb3     \});\cb1 \
\cb3     throw error;\cb1 \
\cb3   \}\cb1 \
\cb3 \};\cb1 \
\cb3 ```\cb1 \
\
\cb3 #### Email Triggers\cb1 \
\
\cb3 **Booking Confirmation Trigger**\cb1 \
\cb3 ```typescript\cb1 \
\cb3 // Stripe webhook handler\cb1 \
\cb3 app.post('/api/stripe/webhook', async (req, res) => \{\cb1 \
\cb3   const event = req.body;\cb1 \
\cb3   \cb1 \
\cb3   if (event.type === 'checkout.session.completed') \{\cb1 \
\cb3     const session = event.data.object;\cb1 \
\cb3     \cb1 \
\cb3     // Create booking from session metadata\cb1 \
\cb3     const booking = await createBookingFromSession(session);\cb1 \
\cb3     \cb1 \
\cb3     // Send confirmation email\cb1 \
\cb3     await sendEmail(\cb1 \
\cb3       BookingConfirmationEmail,\cb1 \
\cb3       booking.parent.email,\cb1 \
\cb3       \{\cb1 \
\cb3         parentName: booking.parent.name,\cb1 \
\cb3         athleteName: booking.athletes[0].name,\cb1 \
\cb3         sessionDate: booking.date,\cb1 \
\cb3         sessionTime: booking.time,\cb1 \
\cb3         lessonType: booking.lessonType,\cb1 \
\cb3         focusAreas: booking.focusAreas\cb1 \
\cb3       \}\cb1 \
\cb3     );\cb1 \
\cb3   \}\cb1 \
\cb3 \});\cb1 \
\cb3 ```\cb1 \
\
\cb3 **Automated Reminders**\cb1 \
\cb3 ```typescript\cb1 \
\cb3 // Cron job for daily reminders\cb1 \
\cb3 const sendDailyReminders = async () => \{\cb1 \
\cb3   const tomorrow = new Date();\cb1 \
\cb3   tomorrow.setDate(tomorrow.getDate() + 1);\cb1 \
\cb3   \cb1 \
\cb3   const upcomingSessions = await getBookingsByDate(tomorrow);\cb1 \
\cb3   \cb1 \
\cb3   for (const booking of upcomingSessions) \{\cb1 \
\cb3     await sendEmail(\cb1 \
\cb3       SessionReminderEmail,\cb1 \
\cb3       booking.parent.email,\cb1 \
\cb3       \{\cb1 \
\cb3         parentName: booking.parent.name,\cb1 \
\cb3         athleteName: booking.athletes[0].name,\cb1 \
\cb3         sessionDate: booking.date,\cb1 \
\cb3         sessionTime: booking.time,\cb1 \
\cb3         focusAreas: booking.focusAreas\cb1 \
\cb3       \}\cb1 \
\cb3     );\cb1 \
\cb3   \}\cb1 \
