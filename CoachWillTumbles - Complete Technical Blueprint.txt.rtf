\cb3 ### Database Operations (Drizzle ORM)\cb1 \
\
\cb3 #### Connection Configuration\cb1 \
\cb3 ```typescript\cb1 \
\cb3 const db = drizzle(postgres(process.env.DATABASE_URL), \{\cb1 \
\cb3   schema: \{\cb1 \
\cb3     parents,\cb1 \
\cb3     athletes,\cb1 \
\cb3     bookings,\cb1 \
\cb3     booking_athletes,\cb1 \
\cb3     focus_areas,\cb1 \
\cb3     booking_focus_areas,\cb1 \
\cb3     waivers,\cb1 \
\cb3     admins,\cb1 \
\cb3     email_logs\cb1 \
\cb3   \}\cb1 \
\cb3 \});\cb1 \
\cb3 ```\cb1 \
\
\cb3 #### Common Query Patterns\cb1 \
\cb3 ```typescript\cb1 \
\cb3 // Get bookings with related data\cb1 \
\cb3 const getBookingsWithRelations = async () => \{\cb1 \
\cb3   return await db.select(\{\cb1 \
\cb3     booking: bookings,\cb1 \
\cb3     parent: parents,\cb1 \
\cb3     athletes: athletes,\cb1 \
\cb3     focusAreas: focus_areas\cb1 \
\cb3   \})\cb1 \
\cb3   .from(bookings)\cb1 \
\cb3   .leftJoin(parents, eq(bookings.parentId, parents.id))\cb1 \
\cb3   .leftJoin(booking_athletes, eq(bookings.id, booking_athletes.bookingId))\cb1 \
\cb3   .leftJoin(athletes, eq(booking_athletes.athleteId, athletes.id))\cb1 \
\cb3   .leftJoin(booking_focus_areas, eq(bookings.id, booking_focus_areas.bookingId))\cb1 \
\cb3   .leftJoin(focus_areas, eq(booking_focus_areas.focusAreaId, focus_areas.id));\cb1 \
\cb3 \};\cb1 \
\cb3 ```\cb1 \
\
\cb3 ### Error Handling & Logging\cb1 \
\
\cb3 #### Error Middleware\cb1 \
\cb3 ```typescript\cb1 \
\cb3 app.use((err: any, req: Request, res: Response, next: NextFunction) => \{\cb1 \
\cb3   console.error('Error:', err);\cb1 \
\cb3   \cb1 \
\cb3   const status = err.status || 500;\cb1 \
\cb3   const message = err.message || 'Internal Server Error';\cb1 \
\cb3   \cb1 \
\cb3   res.status(status).json(\{ \cb1 \
\cb3     error: message,\cb1 \
\cb3     ...(process.env.NODE_ENV === 'development' && \{ stack: err.stack \})\cb1 \
\cb3   \});\cb1 \
\cb3 \});\cb1 \
\cb3 ```\cb1 \
\
\cb3 #### Request Logging\cb1 \
\cb3 ```typescript\cb1 \
\cb3 app.use((req, res, next) => \{\cb1 \
\cb3   const start = Date.now();\cb1 \
\cb3   \cb1 \
\cb3   res.on('finish', () => \{\cb1 \
\cb3     const duration = Date.now() - start;\cb1 \
\cb3     console.log(`$\{req.method\} $\{req.path\} - $\{res.statusCode\} - $\{duration\}ms`);\cb1 \
\cb3   \});\cb1 \
\cb3   \cb1 \
\cb3   next();\cb1 \
\cb3 \});\cb1 \
\cb3 ```\cb1 \
